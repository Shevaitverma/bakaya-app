# -----------------------------------------------------------------------------
# Example Terraform Variables
# Copy this file to terraform.tfvars and fill in your values.
# Never commit terraform.tfvars to version control.
# -----------------------------------------------------------------------------

aws_region    = "ap-south-1"
project_name  = "bakaya"
environment   = "production"
instance_type = "t3.small"
vpc_cidr      = "10.0.0.0/16"

# Name of the key pair created in AWS Console (EC2 → Key Pairs)
key_pair_name = "your-key-pair-name"

# Restrict SSH access to specific IPs (recommended)
# ssh_allowed_cidrs = ["YOUR_IP/32"]

# ACM certificate ARN for HTTPS (provision via AWS Console or CLI first)
# certificate_arn = "arn:aws:acm:ap-south-1:ACCOUNT_ID:certificate/CERTIFICATE_ID"

# Domain name for the application
# domain_name = "bakaya.example.com"
